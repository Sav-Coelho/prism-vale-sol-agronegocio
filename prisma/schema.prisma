// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Unit {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  active  Boolean  @default(true)
  clients Client[]
  sales   Sale[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  cpf       String?
  unitId    Int?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  sales     Sale[]
}

model Sale {
  id            Int       @id @default(autoincrement())
  clientId      Int
  client        Client    @relation(fields: [clientId], references: [id])
  description   String
  amount        Float
  date          DateTime
  dueDate       DateTime?
  paidDate      DateTime?
  paymentStatus String    @default("PENDING") // PENDING / PAID / OVERDUE / DEFAULTED
  unitId        Int?
  unit          Unit?     @relation(fields: [unitId], references: [id])
  month         Int
  year          Int
  createdAt     DateTime  @default(now())
}
