// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Unit {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  active  Boolean  @default(true)
  clients Client[]
  sales   Sale[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  cpf       String?
  unitId    Int?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  sales     Sale[]
}

model Sale {
  id            Int       @id @default(autoincrement())
  clientId      Int
  client        Client    @relation(fields: [clientId], references: [id])
  description   String
  amount        Float
  date          DateTime
  dueDate       DateTime?
  paidDate      DateTime?
  paymentStatus String    @default("PENDING") // PENDING / PAID / OVERDUE / DEFAULTED
  unitId        Int?
  unit          Unit?     @relation(fields: [unitId], references: [id])
  month         Int
  year          Int
  createdAt     DateTime  @default(now())
}

// Títulos a receber importados do ERP do cliente
model Receivable {
  id              Int       @id @default(autoincrement())
  fitid           String    @unique
  dueDate         DateTime
  issueDate       DateTime?
  customerCode    String?
  customerName    String
  customerDoc     String?
  titulo          String
  parcela         String?
  portador        String?
  tipoCobranca    String?
  sellerCode      String?
  sellerName      String?
  farmName        String?
  phone           String?
  amount          Float
  discount        Float     @default(0)
  interest        Float     @default(0)
  fine            Float     @default(0)
  netAmount       Float
  filial          String?
  observation     String?
  status          String    @default("PENDING")    // PENDING / RECEIVED
  receivedDate    DateTime?
  importedAt      DateTime  @default(now())

  @@index([dueDate])
  @@index([customerDoc])
  @@index([status])
}

// Pagamentos a efetuar importados do ERP do cliente
model Payable {
  id              Int       @id @default(autoincrement())
  fitid           String    @unique
  dueDate         DateTime
  entryDate       DateTime?
  supplierCode    String?
  supplierName    String
  supplierDoc     String?
  titulo          String
  parcela         String?
  amount          Float
  discount        Float     @default(0)
  interest        Float     @default(0)
  fine            Float     @default(0)
  netAmount       Float
  portador        String?
  chequeNumber    String?
  tipoDocto       String?
  filial          String?
  operacao        String?
  observation     String?
  status          String    @default("PENDING")    // PENDING / PAID
  paidDate        DateTime?
  importedAt      DateTime  @default(now())

  @@index([dueDate])
  @@index([supplierDoc])
  @@index([status])
}
